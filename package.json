{
  "name": "mioku-plugin-music",
  "version": "2.4.0",
  "description": "音乐插件：点歌、搜索音乐、听歌语音发送",
  "main": "index.ts",
  "type": "module",
  "keywords": [
    "mioku"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mioku-lab/mioku-plugin-music.git"
  },
  "mioku": {
    "services": [
      "config",
      "ai",
      "screenshot"
    ],
    "accessHooks": [
      {
        "id": "点歌",
        "match": "/^\\/?点歌\\s+/"
      },
      {
        "id": "听",
        "match": "/^听\\d+$/"
      },
      {
        "id": "原曲",
        "match": "/^原曲\\d+$/"
      }
    ],
    "help": {
      "title": "音乐",
      "description": "点歌并发送语音，支持搜索结果图片列表",
      "commands": [
        {
          "cmd": "点歌 <歌曲名>",
          "desc": "搜索歌曲/歌手/专辑，返回最多 15 条结果图片列表",
          "usage": "/点歌 晴天",
          "role": "member"
        },
        {
          "cmd": "听 <编号>",
          "desc": "发送上次搜索列表中的指定歌曲语音",
          "usage": "听1",
          "role": "member"
        },
        {
          "cmd": "原曲 <编号>",
          "desc": "发送上次搜索列表中的指定歌曲原曲文件",
          "usage": "原曲1",
          "role": "member"
        }
      ]
    }
  },
  "peerDependencies": {
    "mioku": "^0.8.0",
    "mioki": "^0.16.0",
    "mioku-service-applemusic": "^2.0.0",
    "mioku-service-netease": "^1.0.0"
  },
  "devDependencies": {
    "mioku": "workspace:*",
    "mioki": "^0.16.0",
    "mioku-service-applemusic": "workspace:*",
    "mioku-service-netease": "workspace:*"
  }
}
